source "Kconfig.zephyr"

menu "Nordic Sta sample"

config CONNECTION_IDLE_TIMEOUT
	int "Time to be waited for a station to connect"
	default 30

config NRF70_QSPI_ENCRYPTION_KEY
	string "16 bytes QSPI encryption key, only for testing purposes"
	depends on BOARD_NRF7002DK_NRF5340_CPUAPP
	help
	  Specify the QSPI encryption key

config STA_CONN_TIMEOUT_SEC
	int "Overall Connection timeout i.e., time to be waited for a station to connect and get an IP address"
	# Zephyr DHCP retry is 1 minute, so set the default to 70 seconds
	default 70
	# 512 has no special meaning, just a reasonable upper limit
	range 0 512
	help
	  Specify the connection timeout, in seconds. This is the overall timeout i.e., time to be waited for
	  a station to connect and get an IP address. DHCP retries should be taken into account when setting
	  this value. If the timeout is set to 0, the connection will not timeout.

config STA_SAMPLE_START_WIFI_THREAD_STACK_SIZE
	int "Stack size for Wi-Fi start thread"
	default 4096
	help
	  Set the stack size for the Wi-Fi start thread.

# Wi-Fi management bearer configuration
choice WIFI_MGMT_BEARER
	bool "Enable Wi-Fi management bearer"
	default WIFI_MGMT_BEARER_SERIAL_USB
	help
	  Enable the Wi-Fi management bearer. This allows the sample to use the Wi-Fi management interface
	  for operations such as scanning and connecting to networks.

config WIFI_MGMT_BEARER_SERIAL_UART
	bool "Enable Wi-Fi management bearer over UART"
	help
	  Enable the Wi-Fi management bearer over UART. This allows the sample to communicate with the Wi-Fi
	  management interface using a serial connection.

config WIFI_MGMT_BEARER_SERIAL_USB
	bool "Enable Wi-Fi management bearer over USB"
	help
	  Enable the Wi-Fi management bearer over USB. This allows the sample to communicate with the Wi-Fi
	  management interface using a USB connection.
endchoice

# Host/device role configuration
choice SERIAL_ROLE
	bool "Serial role selection"
	default SERIAL_DEVICE_ROLE
	help
	  Select whether this node operates as an RCP device (responds to host
	  commands over serial) or as a Zephyr host-driver (issues commands to a
	  remote device over serial).

config SERIAL_DEVICE_ROLE
	bool "RCP device role"
	help
	  This node acts as a Radio Co-Processor device. It receives management
	  and data frames from a host over the serial link and calls the
	  corresponding Zephyr Wi-Fi / net_if / BT APIs.

config SERIAL_HOST_ROLE
	bool "Zephyr host-driver role"
	help
	  This node acts as the serial host driver. It sends management and data
	  frames to a remote RCP device and exposes the results to the local
	  Zephyr networking stack.
endchoice

endmenu

rsource "src/serial/Kconfig"
